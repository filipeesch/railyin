{
  "name": "railyin",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-assisted delivery orchestration for software teams",
  "scripts": {
    "postinstall": "bun scripts/postinstall.ts",
    "typecheck": "tsc --noEmit",
    "dev": "bun scripts/dev.ts",
    "prod": "bun src/bun/index.ts",
    "dev:kill": "pkill -f 'src/bun/index.ts' || true",
    "build": "vite build",
    "test": "bun test src/bun --timeout 20000",
    "test:api": "bun test e2e/api --timeout 30000",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test e2e/ui",
    "test:e2e:chat": "npx playwright test e2e/ui/chat.spec.ts",
    "test:e2e:board": "npx playwright test e2e/ui/board.spec.ts",
    "test:e2e:timeline": "npx playwright test e2e/ui/timeline-pipeline.spec.ts",
    "test:e2e:review": "npx playwright test e2e/ui/review-overlay.spec.ts",
    "test:e2e:headed": "npx playwright test --headed",
    "build:ext": "cd extensions/railyin-ref && npm install && npm run compile && npm run package",
    "test:mutation:backend": "stryker run stryker.backend.json",
    "test:mutation:frontend": "stryker run stryker.frontend.json",
    "test:mutation": "bun run test:mutation:backend && bun run test:mutation:frontend"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.204",
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/language": "^6.11.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.7",
    "@cursor/sdk": "^1.0.23",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@github/copilot-sdk": "^0.3.0",
    "@iconify/vue": "^5.0.0",
    "@monaco-editor/loader": "^1.4.0",
    "@opencode-ai/sdk": "^1.14.33",
    "@tanstack/vue-virtual": "^3.13.23",
    "@types/picomatch": "^4.0.3",
    "ajv": "^8.17.1",
    "code-server": "^4.116.0",
    "diff": "^8.0.4",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.5",
    "mermaid": "^11.14.0",
    "minimatch": "^10.2.5",
    "monaco-editor": "^0.55.1",
    "playwright": "^1.59.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@primevue/themes": "^4.0.0",
    "@stryker-mutator/core": "^9.0.0",
    "@stryker-mutator/typescript-checker": "^9.0.0",
    "@stryker-mutator/vitest-runner": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/json-schema": "^7.0.15",
    "@types/marked": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.1.2",
    "pinia": "^2.2.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  }
}
