{
  "name": "railyin",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-assisted delivery orchestration for software teams",
  "scripts": {
    "dev": "vite build && electrobun dev --watch",
    "dev:test": "vite build && RAILYN_DEBUG=1 RAILYN_DB=:memory: electrobun dev --watch",
    "dev:watch": "concurrently -n vite,electrobun -c cyan,magenta \"vite build --watch\" \"electrobun dev --watch\"",
    "build:canary": "vite build && electrobun build --env=canary",
    "test": "bun test src/bun/test --timeout 20000",
    "test:ui": "bun test src/ui-tests --timeout 120000",
    "test:ui:review": "bun test src/ui-tests/review-overlay.test.ts --timeout 120000",
    "test:ui:chat": "bun test src/ui-tests/chat.test.ts --timeout 120000",
    "test:ui:run": "./scripts/run-ui-tests.sh"
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.4.0",
    "electrobun": "latest",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@primevue/themes": "^4.0.0",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "pinia": "^2.2.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  }
}
