{
  "name": "railyin",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-assisted delivery orchestration for software teams",
  "scripts": {
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "dev": "bun scripts/dev.ts",
    "dev:kill": "pkill -f 'src/bun/index.ts' || true",
    "build": "vite build",
    "test": "bun test src/bun/test",
    "test:api": "bun test e2e/api --timeout 30000",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test e2e/ui",
    "test:e2e:chat": "npx playwright test e2e/ui/chat.spec.ts",
    "test:e2e:board": "npx playwright test e2e/ui/board.spec.ts",
    "test:e2e:timeline": "npx playwright test e2e/ui/timeline-pipeline.spec.ts",
    "test:e2e:review": "npx playwright test e2e/ui/review-overlay.spec.ts",
    "test:e2e:headed": "npx playwright test --headed",
    "refine:mock": "bun refinement/runner.ts --mode mock",
    "refine:local": "bun refinement/runner.ts --mode local",
    "refine:live": "bun refinement/runner.ts --mode live",
    "test:ui:run": "bun scripts/run-ui-tests.ts src/ui-tests"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "@github/copilot-sdk": "^0.2.1",
    "@iconify/vue": "^5.0.0",
    "@monaco-editor/loader": "^1.4.0",
    "@tanstack/vue-virtual": "^3.13.23",
    "diff": "^8.0.4",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.5",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@primevue/themes": "^4.0.0",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.1.2",
    "pinia": "^2.2.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  }
}
