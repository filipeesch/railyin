{
  "name": "railyin",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-assisted delivery orchestration for software teams",
  "scripts": {
    "dev": "RAILYN_CLI=1 vite build && RAILYN_CLI=1 electrobun dev --watch",
    "dev:debug": "RAILYN_CLI=1 vite build && RAILYN_CLI=1 electrobun dev --watch -- --debug",
    "dev:test": "bun scripts/run-ui-tests.ts",
    "dev:kill": "pkill -f 'Railyn-dev' || true; pkill -f 'electrobun' || true",
    "dev:watch": "concurrently -n vite,electrobun -c cyan,magenta \"vite build --watch\" \"electrobun dev --watch\"",
    "build:canary": "vite build && electrobun build --env=canary",
    "test": "bun test src/bun/test",
    "test:ui": "bun scripts/run-ui-tests.ts src/ui-tests",
    "test:ui:review": "bun scripts/run-ui-tests.ts src/ui-tests/review-overlay.test.ts",
    "test:ui:chat": "bun scripts/run-ui-tests.ts src/ui-tests/chat.test.ts",
    "test:ui:chat-ext": "bun scripts/run-ui-tests.ts src/ui-tests/extended-chat.test.ts",
    "test:ui:board": "bun scripts/run-ui-tests.ts src/ui-tests/board.test.ts",
    "refine:mock": "bun refinement/runner.ts --mode mock",
    "refine:local": "bun refinement/runner.ts --mode local",
    "refine:live": "bun refinement/runner.ts --mode live",
    "test:ui:run": "bun scripts/run-ui-tests.ts src/ui-tests"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "@github/copilot-sdk": "^0.2.1",
    "@iconify/vue": "^5.0.0",
    "@monaco-editor/loader": "^1.4.0",
    "@tanstack/vue-virtual": "^3.13.23",
    "diff": "^8.0.4",
    "electrobun": "latest",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.5",
    "monaco-editor": "^0.55.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@primevue/themes": "^4.0.0",
    "@types/bun": "latest",
    "@types/diff": "^8.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "pinia": "^2.2.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  }
}
