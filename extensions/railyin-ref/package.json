{
  "name": "railyin-ref",
  "displayName": "Railyin Reference",
  "description": "Send code selections to Railyin AI chat as structured references",
  "version": "0.1.0",
  "publisher": "railyin",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:railyin.sendRef"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "railyin.sendRef",
        "title": "Send to Railyin",
        "category": "Railyin"
      }
    ],
    "keybindings": [
      {
        "command": "railyin.sendRef",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "railyin.sendRef",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "npx vsce package --no-dependencies -o railyin-ref.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
