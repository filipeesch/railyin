# engines.yaml — global engine configuration for Railyin (REQUIRED)
#
# Declares all engine instances available across all workspaces.
# Engines are constructed once at startup and shared.
#
# This file is required. If it is absent or contains no valid entries, Railyin
# will refuse to start with a clear error message.
#
# To restrict which engines a workspace can use, add `allowed_engines:` to workspace.yaml.

engines:
  # GitHub Copilot — uses the GitHub Copilot SDK (requires Copilot auth)
  - id: copilot
    type: copilot

  # Claude — uses the Claude Agent SDK / Claude Code environment (requires Claude Code auth)
  - id: claude
    type: claude

  # OpenCode — local/remote LLM router via the OpenCode AI SDK.
  # Use this engine for Anthropic direct API, OpenRouter, Ollama, LM Studio,
  # or any OpenAI-compatible endpoint.
  #
  # Anthropic direct API:
  # - id: opencode
  #   type: opencode
  #   model: anthropic/claude-sonnet-4-5
  #   providers:
  #     anthropic:
  #       api_key: ${ANTHROPIC_API_KEY}
  #
  # OpenRouter (access to hundreds of models via one API key):
  # - id: openrouter
  #   type: opencode
  #   model: openrouter/meta-llama/llama-3.1-70b-instruct
  #   providers:
  #     openrouter:
  #       base_url: https://openrouter.ai/api/v1
  #       api_key: sk-or-YOUR_KEY_HERE
  #
  # Ollama (local models):
  # - id: ollama
  #   type: opencode
  #   model: ollama/qwen2.5-coder:7b
  #   providers:
  #     ollama:
  #       base_url: http://localhost:11434/v1

  # Pi — local LLM first engine (LM Studio, Ollama, any OpenAI-compatible endpoint)
  # Uses Railyin-native tools with content-hash dedup and per-path undo stack.
  # - id: pi-local
  #   type: pi
  #   model: lmstudio/qwen3-8b   # provider/model-id format
  #   context_window: 128000     # optional; default 128000. Set to your model's
  #                              # actual context window. Auto-compaction fires at
  #                              # (context_window - 16384) tokens. Lower this for
  #                              # small models (e.g. 8192 for Mistral-7B).
  #   providers:
  #     lmstudio:
  #       base_url: http://localhost:1234/v1
  #       max_inflight: 2        # max concurrent requests (default: 8; use 1-2 for LM Studio)
  #       queue_timeout_ms: 60000  # queue wait timeout in ms (default: 60000)
  #       # Note: for vLLM, max_inflight: 8 is a good default
  #       # Note: for Ollama, max_inflight: 4 is recommended
  #   harness:
  #     undo_stack_size: 50      # optional; default 50
  #     delegate:
  #       enabled: true          # set false to disable the delegate tool entirely
  #       max_per_call: 5        # max sub-tasks per delegate call (1-10, default: 5)
  #       # max_concurrency: 3   # optional: override effective concurrency cap
  #       allow_tools:           # tool groups children may use (default: ["read","write","shell"])
  #         - read               # children share the parent worktree and can edit files / run shell
  #         - write
  #         - shell
  #         # - web
  #     background_compaction:
  #       enabled: true          # opportunistic bg compaction (default: true)
  #       early_margin_tokens: 8192  # trigger this many tokens before SDK's hard threshold
  #   # dialect: none            # Slash-command convention to use for this Pi engine.
  #                              # copilot → .github/prompts/*.prompt.md
  #                              # claude  → .claude/commands/**/*.md (colon-namespaced subdirs)
  #                              # none    → no slash commands (default when omitted)
  #
  #   # ── Sampling parameter presets ────────────────────────────────────────────
  #   # Named presets of LLM sampling parameters. Columns can reference a preset
  #   # by name via `sampling_preset: <name>` in the workflow YAML.
  #   # Fallback chain: column.sampling_preset → default_sampling_preset → none
  #   #
  #   # `label` and `description` are optional — used in the UI preset selector.
  #   # The YAML key is used as the stable identifier in column config and the DB.
  #   #
  #   # default_sampling_preset: balanced   # used when a column has no sampling_preset
  #   # sampling_presets:
  #   #   balanced:                         # good all-round default
  #   #     label: "Balanced"
  #   #     description: "Good all-round default for most tasks"
  #   #     temperature: 0.8
  #   #     top_p: 0.95
  #   #   precise:                          # low-variance for code writing / bug fixing
  #   #     label: "Precise / Code"
  #   #     description: "Low variance for deterministic code and bug fixing"
  #   #     temperature: 0.2
  #   #     top_p: 0.85
  #   #   creative:                         # high-variance for brainstorming / exploration
  #   #     label: "Creative / Design"
  #   #     description: "High variance for brainstorming and open-ended exploration"
  #   #     temperature: 1.2
  #   #     top_p: 0.98
  #   #     presence_penalty: 0.3
