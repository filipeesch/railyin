name: My Workspace

# List all AI providers you want to use simultaneously.
# Model IDs are fully-qualified: {provider-id}/{model-id}
# e.g. lmstudio/qwen3-8b, anthropic/claude-3-5-sonnet-20241022, openrouter/meta-llama/llama-3-70b-instruct
providers:
  # LM Studio (local models)
  # - id: lmstudio
  #   type: lmstudio
  #   base_url: http://127.0.0.1:1234/
  #   api_key: ""

  # Anthropic direct API (Claude models)
  # - id: anthropic
  #   type: anthropic
  #   api_key: sk-ant-YOUR_KEY_HERE
  #   # Optional: fall back to this model after 3 consecutive 529 (overloaded) errors.
  #   # Use a fully-qualified model ID from any configured provider.
  #   # fallback_model: anthropic/claude-sonnet-4-20250514

  # OpenRouter (access to many models via one API key)
  # - id: openrouter
  #   type: openrouter
  #   base_url: https://openrouter.ai/api/v1
  #   api_key: sk-or-YOUR_KEY_HERE
  #   # Optional: forwarded verbatim as the `provider` key in every request body.
  #   # Useful for controlling OpenRouter routing (ignore/only/order/sort/etc).
  #   # Example: avoid Azure/Vertex for Claude models to prevent 400 prefill errors.
  #   # provider_args:
  #   #   ignore: [google-vertex, azure]

# Where to store Git worktrees. Defaults to ~/.railyn/worktrees
# worktree_base_path: /path/to/worktrees

# Workspace-level default model (fully-qualified: providerId/modelId).
# Used as a fallback when a column has no model configured and when a task
# is created without an explicit model. Column-level model always takes precedence.
# default_model: anthropic/claude-sonnet-4-5

# Slash prompt references in workflow columns
# on_enter_prompt and stage_instructions accept a /prompt-name reference as the ENTIRE value:
#   on_enter_prompt: /opsx-propose
# This resolves to .github/prompts/opsx-propose.prompt.md in the task's worktree.
# Text after the reference is passed as $input substitution inside the prompt file.
# The slash reference must be at the beginning — inline use (e.g., "see /opsx-propose") is not resolved.
# You can also use slash commands in the task chat: start your message with /opsx-sync.

# Web search (used by the search_internet tool)
# search:
#   engine: tavily   # "tavily" is the only supported engine in v1
#   api_key: ""      # get a free key at https://tavily.com

# Anthropic-specific settings (only applied when using Anthropic provider)
# anthropic:
#   cache_ttl: "5m"  # "5m" (default, 1.25× write cost) or "1h" (2× write cost, survives long pauses)
#   enable_thinking: false  # Set to true to enable adaptive thinking for supported models (Claude 3.7+, Claude 4+).
#   effort: "medium"        # Thinking effort for the parent agent: "low" | "medium" | "high" | "max". Default is "high" (Sonnet 4.6). "medium" is a good balance for most tasks.
#                           # Can also be toggled via Settings → Models in the UI.
